{
  "manifest_version": 3,
  "name": "B2B Loterias - Auto Apostador",
  "version": "1.0.0",
  "description": "Preenche jogos de loteria automaticamente no site da Caixa",
  "permissions": ["storage"],
  "icons": {
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["https://www.loteriasonline.caixa.gov.br/*", "https://loteriasonline.caixa.gov.br/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icon48.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  }
}
